# ==========================================
# AUTHENTICATION (Clerk)
# ==========================================
# Get these from https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook secret for syncing users (Dashboard -> Webhooks)
CLERK_WEBHOOK_SECRET=whsec_...

# ==========================================
# DATABASE (Supabase / Postgres)
# ==========================================
# Get these from https://supabase.com/dashboard -> Project Settings -> Database
# Use the "Transaction" pooler URL for DATABASE_URL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use the direct "Session" URL for Prisma migrations
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ==========================================
# STORAGE (Supabase Storage)
# ==========================================
# Get these from Project Settings -> API
# Required for uploading files to your "study-materials" bucket
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: Set to "local" in development to bypass cloud storage
# STORAGE_PROVIDER=local

# ==========================================
# AI GENERATION (Google Gemini)
# ==========================================
# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Optional: Set to "true" to use fast mock data for UI testing without spending tokens
USE_MOCK_AI=false

# Optional: Override the model (defaults to gemini-2.5-flash-preview-04-17)
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17
